# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/geargap"

# JWT secret (change this in production — use a long random string)
JWT_SECRET="change-me-to-a-long-random-string-in-production"

# ─── Battle.net OAuth ────────────────────────────────────────────────────────
# Create a free app at: https://develop.battle.net/access/clients
BATTLENET_CLIENT_ID="your-client-id"
BATTLENET_CLIENT_SECRET="your-client-secret"

# Optional: only needed if the auto-detected URL is wrong.
# On Vercel this is auto-detected via VERCEL_URL.
# Local dev default: http://localhost:3000/api/auth/callback/battlenet
# BATTLENET_REDIRECT_URI="https://your-app.vercel.app/api/auth/callback/battlenet"

# OpenAI Vision API key (optional — falls back to mock OCR if not set)
OPENAI_API_KEY=""

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
